# Cognira - Environment Variables
# Copy this to .env and fill in your values

# LLM Provider: "gemini" or "deepseek"
LLM_PROVIDER=gemini

# Google Gemini API Key (required if LLM_PROVIDER=gemini)
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Gemini Model to use
GEMINI_MODEL=gemini-2.5-flash

# DeepSeek API Key (required if LLM_PROVIDER=deepseek)
# Get from: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# DeepSeek Model to use
DEEPSEEK_MODEL=deepseek-chat

# Redis URL for state persistence (optional - uses MemorySaver if not set)
# Install Redis: docker run -d -p 6379:6379 redis:latest
# REDIS_URL=redis://localhost:6379

# Token Budget (in USD) - pause execution if exceeded
TOKEN_BUDGET=2.00
